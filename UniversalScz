local ThemeObjects = { Headers = {}, Texts = {}, SubTexts = {}, Inputs = {} }
local currentTheme = "Dark"

local function applyThemeColor(object, typeOfObj, theme)
    if theme == "Dark" then
        MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        if typeOfObj == "Header" then object.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        elseif typeOfObj == "Text" then object.TextColor3 = Color3.fromRGB(255, 255, 255)
        elseif typeOfObj == "SubText" then object.TextColor3 = Color3.fromRGB(200, 200, 200)
        elseif typeOfObj == "Input" then object.BackgroundColor3 = Color3.fromRGB(45, 45, 45); object.TextColor3 = Color3.fromRGB(255, 255, 255) end
    else
        MainFrame.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
        if typeOfObj == "Header" then object.BackgroundColor3 = Color3.fromRGB(215, 215, 215)
        elseif typeOfObj == "Text" then object.TextColor3 = Color3.fromRGB(30, 30, 30)
        elseif typeOfObj == "SubText" then object.TextColor3 = Color3.fromRGB(70, 70, 70)
        elseif typeOfObj == "Input" then object.BackgroundColor3 = Color3.fromRGB(200, 200, 200); object.TextColor3 = Color3.fromRGB(30, 30, 30) end
    end
end

local function switchTheme(theme)
    currentTheme = theme
    applyThemeColor(MainFrame, "MainFrame", theme)
    for _, obj in pairs(ThemeObjects.Headers) do applyThemeColor(obj, "Header", theme) end
    for _, obj in pairs(ThemeObjects.Texts) do applyThemeColor(obj, "Text", theme) end
    for _, obj in pairs(ThemeObjects.SubTexts) do applyThemeColor(obj, "SubText", theme) end
    for _, obj in pairs(ThemeObjects.Inputs) do applyThemeColor(obj, "Input", theme) end
end

