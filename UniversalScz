-- 4. MEGA LASER DESTROYER SYSTEM WITH SAFE BOUNDS
local Mouse = LocalPlayer:GetMouse()
Mouse.Button1Down:Connect(function()
    if not GokuConfig.LaserEnabled then return end
    
    local targetBlock = Mouse.Target
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if targetBlock and targetBlock:IsA("BasePart") and targetBlock.Name ~= "Baseplate" and not targetBlock:IsDescendantOf(char) and hrp and hum then
        
        local currentData = FormDatabase[GokuConfig.CurrentForm]
        if not currentData then return end
        
        local powerMultiplier = _G.DeltaPowerLimiter / 100
        local amarahMultiplier = (GokuConfig.AmarahEnabled and _G.DeltaAmarahMultiplier) or 1
        
        local finalBlastRadius = currentData.BlastRadius * powerMultiplier * amarahMultiplier
        local finalBlastPower = currentData.BlastPower * powerMultiplier * amarahMultiplier
        local finalLaserThickness = currentData.LaserThickness * math.clamp(powerMultiplier, 0.1, 1) * amarahMultiplier
        
        local originPos = hrp.Position + Vector3.new(0, 1, 0)
        local targetPos = Mouse.Hit.p

        if (targetPos - hrp.Position).Magnitude < 6 then return end

        -- A. BEAM VISUAL
        local distance = (targetPos - originPos).Magnitude
        local laserPart = Instance.new("Part", workspace)
        laserPart.Name = "Goku_Mega_Laser"
        laserPart.Anchored = true
        laserPart.CanCollide = false
        laserPart.Color = currentData.LaserColor
        laserPart.Material = Enum.Material.Neon
        laserPart.Size = Vector3.new(math.clamp(finalLaserThickness, 1, 500), math.clamp(finalLaserThickness, 1, 500), distance)
        laserPart.CFrame = CFrame.new(originPos, targetPos) * CFrame.new(0, 0, -distance/2)
        game:GetService("Debris"):AddItem(laserPart, 0.25)

        -- B. BASE EXPLOSION
        local explosion = Instance.new("Explosion")
        explosion.Position = targetPos
        explosion.BlastRadius = math.clamp(finalBlastRadius, 1, 500) -- Batas aman Roblox Engine
        explosion.BlastPressure = finalBlastPower * 50
        explosion.ExplosionType = Enum.ExplosionType.NoCraters
        explosion.Hit:Connect(function(partHit)
            if partHit and partHit:IsDescendantOf(char) then hum.Health = hum.Health end
        end)
        explosion.Parent = workspace

        -- C. DESTROY TARGET INSTANTLY
        targetBlock:Destroy()

        -- D. TITANIC SPLASH ERASURE (SAFE MATRIX FOR EXTREME VALUES)
        local regionSize = math.clamp(finalBlastRadius, 5, 250) -- Dikecilkan max-nya agar tidak bikin game freeze
        local region = Region3.new(
            targetPos - Vector3.new(regionSize/2, regionSize/2, regionSize/2), 
            targetPos + Vector3.new(regionSize/2, regionSize/2, regionSize/2)
        )
        
        local partsInRadius = workspace:FindPartsInRegion3(region, char, 200)
        for _, part in pairs(partsInRadius) do
            if part:IsA("BasePart") and part.Name ~= "Baseplate" and not part:IsDescendantOf(char) then
                part:Destroy()
            end
        end
    end
end)

