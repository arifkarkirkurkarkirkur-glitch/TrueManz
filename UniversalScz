createSimpleButton(SpawnerFrame, "Get Dragging block (HP/PC)", function()
    local DragTool = Instance.new("Tool") DragTool.Name = "Dragging Block Tool"; DragTool.RequiresHandle = true; createInvisibleHandle(DragTool)
    local targetPart = nil local dragConnection = nil local originalCanCollide = true local mouse = LocalPlayer:GetMouse() local camera = workspace.CurrentCamera
    
    -- Jarak default jika jari menunjuk ke langit kosong (tidak mengenai part apapun)
    local defaultDistance = 18 

    -- FUNGSI HITUNG KOORDINAT AKURAT (ANTI OVERLAP / BENTROK BLOCK LAIN)
    local function hitungPosisiAmanJari()
        local mouseX = mouse.X
        local mouseY = mouse.Y
        local unitRay = camera:ScreenPointToRay(mouseX, mouseY)
        
        -- Setelan Raycast untuk mendeteksi objek apa yang ditunjuk oleh jari kamu
        local raycastParams = RaycastParams.new()
        raycastParams.FilterDescendantsInstances = {targetPart, LocalPlayer.Character}
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        
        -- Tembakkan garis deteksi sejauh 500 stud ke depan arah jari
        local raycastResult = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, raycastParams)
        
        if raycastResult and targetPart then
            -- BACA NORMAL PERMUKAAN: Tempatkan block pas menempel di permukaan luar objek yang ditunjuk jari (bukan di dalamnya!)
            local hitPosition = raycastResult.Position
            local hitNormal = raycastResult.Normal -- Arah luar permukaan (Atas, Samping, Bawah)
            
            -- Kalkulasi matematika agar titik tengah block pas berada di luar permukaan target
            local posisiSempurna = hitPosition + (hitNormal * (targetPart.Size / 2))
            return CFrame.new(posisiSempurna)
        else
            -- Jika menunjuk ke langit kosong, pakai jarak default
            return CFrame.new(unitRay.Origin + (unitRay.Direction * defaultDistance))
        end
    end

    local function taruhBlockDiTempat(part, collideState)
        if dragConnection then dragConnection:Disconnect() dragConnection = nil end
        mouse.TargetFilter = nil
        
        if part and part.Parent then
            -- AMBIL POSISI SURFACE: Mengunci posisi tepat di atas/luar permukaan yang ditunjuk jari saat dilepas
            local finalCFrame = hitungPosisiAmanJari()
            
            part.Anchored = true
            part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            part.CFrame = finalCFrame
            
            -- Karena posisinya sudah di luar permukaan block lain, menyalakan CanCollide sekarang 100% aman dan tidak akan amblas!
            task.wait(0.02)
            part.CanCollide = collideState
        end
    end

    DragTool.Activated:Connect(function()
        -- 1. Klik kedua kali = TARUH
        if targetPart then
            local partToRelease = targetPart local collideState = originalCanCollide
            targetPart = nil
            taruhBlockDiTempat(partToRelease, collideState)
            return
        end
        
        -- 2. Klik pertama kali = SERET
        local currentTarget = mouse.Target
        if currentTarget and currentTarget.Name ~= "Baseplate" and not currentTarget:IsDescendantOf(LocalPlayer.Character) then
            targetPart = currentTarget originalCanCollide = targetPart.CanCollide 
            targetPart.Anchored = true targetPart.CanCollide = false mouse.TargetFilter = targetPart 
            
            dragConnection = RunService.Heartbeat:Connect(function()
                if targetPart and targetPart.Parent and DragTool.Parent == LocalPlayer.Character then
                    -- Saat diseret, posisinya langsung nempel rapi mengikuti kontur permukaan block lain
                    targetPart.CFrame = hitungPosisiAmanJari()
                else
                    if dragConnection then dragConnection:Disconnect() dragConnection = nil end mouse.TargetFilter = nil if targetPart then targetPart.CanCollide = originalCanCollide end targetPart = nil
                end
            end)
        end
    end)
    
    -- 3. Lepas Tool Mendadak / Ganti Tool = TARUH DI PERMUKAAN TERAKHIR
    DragTool.Unequipped:Connect(function()
        if targetPart then
            local partToRelease = targetPart local collideState = originalCanCollide
            targetPart = nil
            taruhBlockDiTempat(partToRelease, collideState)
        else
            if dragConnection then dragConnection:Disconnect() dragConnection = nil end mouse.TargetFilter = nil
        end
    end)

    giveToolToPlayer(DragTool)
end)

