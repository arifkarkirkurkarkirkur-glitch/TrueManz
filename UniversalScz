-- FUNGSI VALIDASI BENTUK PART (ANTI BULAT / CYLINDER)
local function isPartValidForLayer(part)
    if not part:IsA("BasePart") or not part.CanCollide or part.Size.X < 1.5 or part.Size.Z < 1.5 then
        return false
    end
    if part:IsA("Part") and (part.Shape == Enum.PartType.Ball or part.Shape == Enum.PartType.Cylinder) then
        return false
    end
    if part.CFrame.UpVector.Y <= 0.85 then
        return false
    end
    return true
end

