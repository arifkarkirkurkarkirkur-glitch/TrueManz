-- XI. SISTEM SIKLUS WAKTU DINAMIS & FENOMENA OTOMATIS ⏰⚡
-- ====================================================================

-- State untuk menyalakan/mematikan siklus waktu
_G.SiklusWaktuAktif = false

local function JalankanSiklusWaktu(enable)
    _G.SiklusWaktuAktif = enable
    
    if not enable then
        if _G.DeltaVisualLoops["SiklusWaktu"] then 
            task.cancel(_G.DeltaVisualLoops["SiklusWaktu"]) 
            _G.DeltaVisualLoops["SiklusWaktu"] = nil 
        end
        return
    end
    
    if _G.DeltaVisualLoops["SiklusWaktu"] then return end
    
    _G.DeltaVisualLoops["SiklusWaktu"] = task.spawn(function()
        -- 1 menit real = 1 jam game (60 detik real = 1 jam game)
        -- Berarti setiap 1 detik real, waktu game bertambah: 1 / 60 jam = 0.01666 jam (atau 1 menit game)
        local WaktuPerDetik = 1 / 60 
        
        while _G.SiklusWaktuAktif do
            local jamSekarang = Lighting.ClockTime
            local jamBaru = (jamSekarang + WaktuPerDetik) % 24
            Lighting.ClockTime = jamBaru
            
            -- ========================================================
            -- MANAJEMEN FENOMENA OTOMATIS BERDASARKAN JAM GAME 🌌
            -- ========================================================
            
            -- 1. KABUT PAGI SEJUK (Jam 05:00 - 07:00)
            if jamBaru >= 5.0 and jamBaru < 7.0 then
                if not _G.FiturAktif_KabutPagi then
                    _G.FiturAktif_KabutPagi = true
                    SetKabutPagi(true)
                end
            elseif _G.FitirAktif_KabutPagi and (jamBaru >= 7.0 or jamBaru < 5.0) then
                _G.FiturAktif_KabutPagi = false
                SetKabutPagi(false)
            end
            
            -- 2. GERHANA MATAHARI TOTAL (Jam 11:30 - 12:30 siang)
            if jamBaru >= 11.5 and jamBaru < 12.5 then
                if not _G.FiturAktif_GerhanaMatahari then
                    _G.FiturAktif_GerhanaMatahari = true
                    -- Trigger Gerhana Matahari
                    Lighting.Brightness = 0
                    Lighting.OutdoorAmbient = Color3.fromRGB(15, 15, 20)
                    Lighting.FogColor = Color3.fromRGB(10, 10, 15)
                    Lighting.FogEnd = 200
                end
            elseif _G.FiturAktif_GerhanaMatahari and (jamBaru >= 12.5 or jamBaru < 11.5) then
                _G.FiturAktif_GerhanaMatahari = false
                -- Kembalikan pencahayaan siang normal
                Lighting.Brightness = 2
                Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
                Lighting.FogColor = Color3.fromRGB(192, 192, 192)
                Lighting.FogEnd = 100000
            end

            -- 3. GERHANA BULAN / BLOODMOON ESTETIK (Jam 21:00 - 23:00 malam)
            if jamBaru >= 21.0 and jamBaru < 23.0 then
                if not _G.FiturAktif_Bloodmoon then
                    _G.FiturAktif_Bloodmoon = true
                    Lighting.Brightness = 0.8
                    Lighting.OutdoorAmbient = Color3.fromRGB(150, 80, 120) -- Pink/Ungu pastel tidak seram
                    Lighting.FogColor = Color3.fromRGB(45, 30, 50)
                    Lighting.FogEnd = 1200
                end
            elseif _G.FiturAktif_Bloodmoon and (jamBaru >= 23.0 or jamBaru < 21.0) then
                _G.FiturAktif_Bloodmoon = false
                -- Kembalikan pencahayaan malam normal
                Lighting.Brightness = 0.5
                Lighting.OutdoorAmbient = Color3.fromRGB(20, 20, 40)
                Lighting.FogColor = Color3.fromRGB(10, 10, 25)
                Lighting.FogEnd = 800
            end

            -- 4. AURORA BLUE-PURPLE (Jam 00:00 - 03:00 subuh)
            if jamBaru >= 0.0 and jamBaru < 3.0 then
                if not _G.FiturAktif_Aurora then
                    _G.FiturAktif_Aurora = true
                    setCustomSkybox(12073934337, "Aurora")
                    Lighting.Brightness = 0
                    Lighting.OutdoorAmbient = Color3.fromRGB(130, 50, 250)
                    Lighting.FogColor = Color3.fromRGB(15, 20, 60)
                    Lighting.FogEnd = 350
                end
            elseif _G.FiturAktif_Aurora and (jamBaru >= 3.0 and jamBaru < 5.0) then -- Matikan setelah lewat jam 3
                _G.FiturAktif_Aurora = false
                resetSkybox()
            end
            
            task.wait(1) -- Update mendeteksi per detik real-time
        end
    end)
end

