    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0, 140, 0, 25); box.Position = UDim2.new(1, -155, 0, 5); box.BackgroundColor3 = Color3.fromRGB(45, 45, 45); box.TextColor3 = Color3.fromRGB(255, 255, 255); box.PlaceholderText = placeholder; box.Text = ""; box.Parent = Row
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    table.insert(ThemeObjects.Inputs, box)
    box.FocusLost:Connect(function() callback(box.Text) end)
