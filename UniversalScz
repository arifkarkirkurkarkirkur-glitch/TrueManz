-- UTILITY: SISTEM MANAGEMENT SUARA
local function playThemeSound(soundId, volume, name)
    if soundCache[name] then soundCache[name]:Destroy() soundCache[name] = nil end
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://" .. tostring(soundId)
    sound.Volume = 0
    sound.Looped = true
    sound.Name = "DeltaSound_" .. name
    sound.Parent = Lighting
    sound:Play()
    TweenService:Create(sound, TweenInfo.new(1.5), {Volume = volume}):Play()
    soundCache[name] = sound
end

local function stopThemeSound(name)
    local sound = soundCache[name]
    if sound then
        local tween = TweenService:Create(sound, TweenInfo.new(1.5), {Volume = 0})
        tween:Play()
        tween.Completed:Connect(function()
            if sound then sound:Destroy() if soundCache[name] == sound then soundCache[name] = nil end end
        end)
    end
end

