local function updateServerNetworkInfo()
    local allPlayers = Players:GetPlayers()
    PlayerCountLabel.Text = "      👥 Jumlah Player di Server : " .. #allPlayers
    
    local friendCount = 0
    for _, p in pairs(allPlayers) do
        if p ~= LocalPlayer then
            local success, isFriend = pcall(function() return LocalPlayer:IsFriendsWith(p.UserId) end)
            if success and isFriend then friendCount = friendCount + 1 end
        end
    end
    FriendCountLabel.Text = "      🤝 Jumlah Teman di Server : " .. friendCount
end
