end

local function createToggle(parent, label, callback)
    local Row = Instance.new("Frame")
    Row.Size = UDim2.new(1, 0, 0, 35); Row.BackgroundTransparency = 1; Row.Parent = parent
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(0, 200, 1, 0); txt.Text = "      " .. label; txt.TextColor3 = Color3.fromRGB(230, 230, 230); txt.BackgroundTransparency = 1; txt.TextXAlignment = Enum.TextXAlignment.Left; txt.Position = UDim2.new(0, 15, 0, 0); txt.Parent = Row
    table.insert(ThemeObjects.SubTexts, txt)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 60, 0, 25); btn.Position = UDim2.new(1, -75, 0, 5); btn.BackgroundColor3 = Color3.fromRGB(150, 50, 50); btn.Text = "OFF"; btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.Parent = Row
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    local enabled = false
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then btn.BackgroundColor3 = Color3.fromRGB(50, 150, 50) btn.Text = "ON" else btn.BackgroundColor3 = Color3.fromRGB(150, 50, 50) btn.Text = "OFF" end
        callback(enabled)
    end)
    return btn
end

