local function getBackupTarget()
    local available = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") then
            if p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then table.insert(available, p) end
        end
    end
    if #available > 0 then return available[math.random(1, #available)] end
    return nil
end

local function spawnDrone(targetPlayer, isRandomType)
    if not targetPlayer then return end
    DroneCount = DroneCount + 1
    local droneId = string.format("%02d", DroneCount)
    
    local dronePart = Instance.new("Part")
    dronePart.Name = "Drone_" .. droneId
    dronePart.Size = Vector3.new(3, 0.4, 3)
    dronePart.Anchored = true
    dronePart.CanCollide = true
    dronePart.Material = Enum.Material.SmoothPlastic
    dronePart.Parent = workspace
    
    local Seat = Instance.new("Seat")
    Seat.Name = "DroneSeat"
    Seat.Size = Vector3.new(2, 0.6, 2)
    Seat.Anchored = false
    Seat.CanCollide = true
    Seat.Parent = dronePart
    Seat.CFrame = dronePart.CFrame * CFrame.new(0, 0.3, 0)
    
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = dronePart; weld.Part1 = Seat; weld.Parent = dronePart
    
    local function CreatePropeller(x, z)
        local arm = Instance.new("Part")
        arm.Size = Vector3.new(0.3, 0.3, 2); arm.Material = Enum.Material.Neon; arm.Color = Color3.fromRGB(255, 255, 255); arm.Anchored = true; arm.CanCollide = false; arm.Parent = workspace
        local rotor = Instance.new("Part")
        rotor.Shape = Enum.PartType.Cylinder; rotor.Size = Vector3.new(0.2, 2, 2); rotor.Material = Enum.Material.Neon; rotor.Color = Color3.fromRGB(0, 255, 255); rotor.Anchored = true; rotor.CanCollide = false; rotor.Parent = workspace
        return {arm, rotor, x, z}
    end

    local Props = { CreatePropeller(2.5, 2.5), CreatePropeller(-2.5, 2.5), CreatePropeller(2.5, -2.5), CreatePropeller(-2.5, -2.5) }
    local bgui = Instance.new("BillboardGui", dronePart)
    bgui.AlwaysOnTop = true; bgui.Size = UDim2.new(0, 150, 0, 30); bgui.ExtentsOffset = Vector3.new(0, 2, 0)
    local tl = Instance.new("TextLabel", bgui)
    tl.Size = UDim2.new(1, 0, 1, 0); tl.BackgroundTransparency = 1; tl.TextColor3 = Color3.fromRGB(255, 255, 0); tl.TextSize = 14; tl.Font = Enum.Font.SourceSansBold; tl.Text = "Drone " .. droneId .. " -> " .. targetPlayer.Name
    
    local droneData = { Part = dronePart, Seat = Seat, Props = Props, Label = tl, Target = targetPlayer, RandomType = isRandomType, IsRiding = false, LockDelay = false }
    ActiveDrones[droneId] = droneData
    
    Seat:GetPropertyChangedSignal("Occupant"):Connect(function()
        local occupant = Seat.Occupant
        if occupant and occupant.Character == LocalPlayer.Character then droneData.IsRiding = true else droneData.IsRiding = false end
    end)

    local spin = 0
    local moveConn
    moveConn = RunService.Heartbeat:Connect(function()
        if not dronePart or not dronePart.Parent then 
            for _, p in pairs(Props) do p[1]:Destroy(); p[2]:Destroy() end
            if Seat then Seat:Destroy() end
            moveConn:Disconnect(); return 
        end
        
        local currentTarget = droneData.Target
        local targetDeadOrGone = true
        
        if currentTarget and currentTarget.Parent and currentTarget.Character and currentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then targetDeadOrGone = false end
        end
        
        if targetDeadOrGone then
            local nextTarget = getBackupTarget()
            if nextTarget then
                droneData.Target = nextTarget; tl.Text = "Drone " .. droneId .. " -> " .. nextTarget.Name; currentTarget = nextTarget
            else
                tl.Text = "Drone " .. droneId .. " -> Menunggu Target..."; currentTarget = nil
            end
        end
        
        if currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local targetPos = currentTarget.Character.HumanoidRootPart.Position + Vector3.new(0, DroneHeight, 0)
            dronePart.CFrame = CFrame.new(targetPos) * CFrame.Angles(0, math.rad(spin*0.1), 0)
            
            if droneData.IsRiding and not droneData.LockDelay then
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = droneData.Seat.CFrame + Vector3.new(0, 1, 0)
                    hrp.AssemblyLinearVelocity = Vector3.zero; hrp.AssemblyAngularVelocity = Vector3.zero
                end
            end
            
            spin = spin + 20
            for _, p in pairs(Props) do
                local arm, rotor, x, z = p[1], p[2], p[3], p[4]
                arm.CFrame = dronePart.CFrame * CFrame.new(x, 0, z)
                rotor.CFrame = dronePart.CFrame * CFrame.new(x, 0.2, z) * CFrame.Angles(0, math.rad(spin), math.rad(90))
            end
        end
    end)
end

local function executeSit(id)
    local droneData = ActiveDrones[id]
    if not droneData then return end
    local seat = droneData.Seat; local char = LocalPlayer.Character
    if seat and char then
        local hum = char:FindFirstChildOfClass("Humanoid"); local hrp = char:FindFirstChild("HumanoidRootPart")
        if hum and hrp then
            droneData.LockDelay = true; hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
            task.wait(0.1); hum.Sit = true; task.wait(0.1); seat:Sit(hum); task.wait(0.3)
            droneData.IsRiding = true; droneData.LockDelay = false
        end
    end
end

local function executeTp(id)
    local droneData = ActiveDrones[id]
    if droneData and droneData.Part and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame = droneData.Part.CFrame * CFrame.new(0, 2.5, 0)
    end
end

