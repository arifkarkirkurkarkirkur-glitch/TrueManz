local function SetXrayVisionMode(enable)
    if enable then
        for _, part in pairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and not part:IsDescendantOf(LocalPlayer.Character) then
                if part.Name == "DeltaSnowTop" or part.Name == "DeltaWaterTop" or part.Name == "DeltaSandTop" or part.Parent == smokeFolder or part.Parent == rainFolder then 
                    continue 
                end
                if not originalTransparencies[part] then
                    originalTransparencies[part] = part.Transparency
                end
                part.Transparency = 0.75
            end
        end
    else
        for part, originalVal in pairs(originalTransparencies) do
            if part and part.Parent then part.Transparency = originalVal end
        end
        table.clear(originalTransparencies)
    end
end

