local URL_SKRIP = "https://raw.githubusercontent.com/arifkarkirkurkarkirkur-glitch/TrueManz/refs/heads/main/PremiumProSc"
local NAMA_FILE = "TrueManz_Session.json"
local DURASI_DETIK = 864000 -- Durasi 10 hari (86400 * 10)
local HttpService = game:GetService("HttpService")

-- --- FUNGSI SISTEM ---
local function isKeyValid(input)
    for _, key in pairs(WHITELISTED_KEYS) do
        if input == key then
            return true
        end
    end
    return false
end

local function saveSession()
    local data = {date = os.time()}
    writefile(NAMA_FILE, HttpService:JSONEncode(data))
end

local function checkSession()
    if isfile(NAMA_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(NAMA_FILE)) end)
        if success and data and os.time() - data.date < DURASI_DETIK then
            return true
        else
            delfile(NAMA_FILE)
        end
    end
    return false
end

