Submit.Text = "LOGIN"
Submit.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
Instance.new("UICorner", Submit)

-- --- LOGIKA EKSEKUSI ---
local function runScript()
    ScreenGui:Destroy()
    loadstring(game:HttpGet(URL_SKRIP))()
end

if checkSession() then
    runScript()
else
    Submit.MouseButton1Click:Connect(function()
        if isKeyValid(Input.Text) then
            saveSession()
            runScript()
        else
            Input.Text = ""
            Input.PlaceholderText = "Key Salah!"
        end
    end)
end
