local function buildPortalDesign(position, targetCFrame, isExitPortal)
    local ModelContainer = Instance.new("Model", workspace) ModelContainer.Name = isExitPortal and "Exit_Portal" or "Entrance_Portal"
    
    local BasePart = Instance.new("Part", ModelContainer) BasePart.Size = Vector3.new(customPondasiLebar, 0.4, customPondasiPanjang) BasePart.Anchored = true; BasePart.CFrame = targetCFrame * CFrame.new(0, -3.3, 0)
    BasePart.Color = Color3.fromRGB(0, 0, 0); BasePart.Material = Enum.Material.Plastic
    
    local StepPart = Instance.new("Part", ModelContainer) StepPart.Size = Vector3.new(math.max(2, customPondasiLebar - 2), 0.4, math.max(1, customPondasiPanjang - 1)) StepPart.Anchored = true; StepPart.CFrame = BasePart.CFrame * CFrame.new(0, 0.4, 0)
    StepPart.Color = Color3.fromRGB(15, 15, 15); StepPart.Material = Enum.Material.Plastic

    local mainColor = isExitPortal and Color3.fromRGB(255, 100, 0) or Color3.fromRGB(0, 255, 150)
    local subColor = isExitPortal and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(0, 150, 255)
    local function makeRing(size, thickness) local r = Instance.new("Part", ModelContainer) r.Size = Vector3.new(size, size, thickness) r.Shape = Enum.PartType.Cylinder; r.Material = Enum.Material.Neon; r.Color = mainColor; r.Anchored = true; r.CanCollide = false; r.CFrame = targetCFrame; return r end
    local Ring1 = makeRing(customRingBesar, 0.8) local Ring2 = makeRing(customRingBesar - 0.5, 0.6) Ring2.Color = subColor
