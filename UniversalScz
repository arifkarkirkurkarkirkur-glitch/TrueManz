-- SYSTEM REFRESH AURA ENGINE
refreshAuraVisual = function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, child in pairs(char:GetChildren()) do if child.Name == "DeltaAuraCorePart" then child:Destroy() end end
    for _, child in pairs(hrp:GetChildren()) do if child.Name == "DeltaAuraCorePart" or child.Name == "GokuAuraAttachment" then child:Destroy() end end

    if GokuConfig.AuraEnabled then
        local currentData = FormDatabase[GokuConfig.CurrentForm]
        local powerMultiplier = _G.DeltaPowerLimiter / 100
        local amarahMultiplier = (GokuConfig.AmarahEnabled and _G.DeltaAmarahMultiplier) or 1
        
        -- Batas Kritis Maks Ukuran Aura agar Layar Roblox Tidak Putus/Crash
        local finalAuraSize = currentData.AuraSize * powerMultiplier * (1 + (amarahMultiplier * 0.03))
        finalAuraSize = math.clamp(finalAuraSize, 1, 150) 

        local auraCore = Instance.new("Part")
        auraCore.Name = "DeltaAuraCorePart"
        auraCore.Size = Vector3.new(1, 1, 1)
        auraCore.Transparency = 1
        auraCore.CanCollide = false
        auraCore.Massless = true
        auraCore.CFrame = hrp.CFrame
        auraCore.Parent = char

        local weld = Instance.new("WeldConstraint")
        weld.Part0 = hrp
        weld.Part1 = auraCore
        weld.Parent = auraCore

        local emitter = Instance.new("ParticleEmitter")
        emitter.LightEmission = 0.85
        emitter.LightInfluence = 0
        emitter.Texture = "rbxassetid://241902296"
        emitter.Color = ColorSequence.new(currentData.AuraColor)
        
        emitter.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, finalAuraSize * 0.4),
            NumberSequenceKeypoint.new(0.4, finalAuraSize),
            NumberSequenceKeypoint.new(1, 0)
        })
        
        emitter.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.6),
            NumberSequenceKeypoint.new(0.2, 0.1),
            NumberSequenceKeypoint.new(0.7, 0.3),
            NumberSequenceKeypoint.new(1, 1)
        })
        
        emitter.Lifetime = NumberRange.new(0.5, 1.0)
        emitter.Rate = math.clamp(140 * (1 + (amarahMultiplier * 0.02)), 10, 300)
        emitter.Speed = NumberRange.new(6 * amarahMultiplier, 14 * amarahMultiplier)
        emitter.Acceleration = Vector3.new(0, 12 * amarahMultiplier, 0)
        emitter.Parent = auraCore
    end
end

