local function createEspForPlayer(player)
    if player == LocalPlayer then return end
    local Billboard = Instance.new("BillboardGui", EspFolder)
    Billboard.AlwaysOnTop = true; Billboard.Size = UDim2.new(0, 200, 0, 50); Billboard.ExtentsOffset = Vector3.new(0, 3, 0)
    local InfoLabel = Instance.new("TextLabel", Billboard)
    InfoLabel.Size = UDim2.new(1, 0, 1, 0); InfoLabel.BackgroundTransparency = 1; InfoLabel.TextColor3 = Color3.fromRGB(255, 255, 255); InfoLabel.TextStrokeTransparency = 0; InfoLabel.TextSize = 14; InfoLabel.Font = Enum.Font.SourceSansBold
    local BoxHighlight = Instance.new("Highlight", EspFolder)
    BoxHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; BoxHighlight.FillTransparency = 1; BoxHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    local TracerLine = Instance.new("Frame", ScreenGui)
    TracerLine.BorderSizePixel = 0; TracerLine.Visible = false
    local SkeletonParts = {}

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not player or not player.Parent then Billboard:Destroy(); BoxHighlight:Destroy(); TracerLine:Destroy(); for _, v in pairs(SkeletonParts) do v:Destroy() end connection:Disconnect(); return end
        local char = player.Character; local root = char and char:FindFirstChild("HumanoidRootPart"); local hum = char and char:FindFirstChildOfClass("Humanoid")
        TracerLine.Visible = false; for _, v in pairs(SkeletonParts) do v:Destroy() end; table.clear(SkeletonParts)

        if root and hum and hum.Health > 0 then
            local vector, onScreen = Camera:WorldToViewportPoint(root.Position)
            if ESP_Config.Nama or ESP_Config.Jarak or ESP_Config.Health then
                Billboard.Adornee = root
                local displayStr = ""
                if ESP_Config.Nama then displayStr = displayStr .. player.Name .. " " end
                if ESP_Config.Jarak then 
                    local dist = math.floor((LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude) or 0)
                    displayStr = displayStr .. "[" .. dist .. "m] "
                end
                if ESP_Config.Health then displayStr = displayStr .. "\nHP: " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) end
                InfoLabel.Text = displayStr
            else Billboard.Adornee = nil end
            if ESP_Config.Box then BoxHighlight.Adornee = char else BoxHighlight.Adornee = nil end
            if ESP_Config.Tali and onScreen then
                TracerLine.BackgroundColor3 = ESP_Config.EspColor
                local fromPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                local toPos = Vector2.new(vector.X, vector.Y)
                TracerLine.Size = UDim2.new(0, (toPos - fromPos).Magnitude, 0, 2)
                TracerLine.Position = UDim2.new(0, (fromPos.X + toPos.X) / 2, 0, (fromPos.Y + toPos.Y) / 2)
                TracerLine.Rotation = math.deg(math.atan2(toPos.Y - fromPos.Y, toPos.X - fromPos.X))
                TracerLine.AnchorPoint = Vector2.new(0.5, 0.5); TracerLine.Visible = true
            end
            if ESP_Config.Skeleton then
                local function drawBone(p1, p2)
                    if p1 and p2 then
                        local pos1, os1 = Camera:WorldToViewportPoint(p1.Position)
                        local pos2, os2 = Camera:WorldToViewportPoint(p2.Position)
                        if os1 and os2 then
                            local line = Instance.new("Frame", ScreenGui)
                            line.BorderSizePixel = 0; line.BackgroundColor3 = ESP_Config.EspColor
                            line.Size = UDim2.new(0, (Vector2.new(pos2.X, pos2.Y) - Vector2.new(pos1.X, pos1.Y)).Magnitude, 0, ESP_Config.BoneThickness)
                            line.Position = UDim2.new(0, (pos1.X + pos2.X)/2, 0, (pos1.Y + pos2.Y)/2)
                            line.Rotation = math.deg(math.atan2(pos2.Y - pos1.Y, pos2.X - pos1.X))
                            line.AnchorPoint = Vector2.new(0.5, 0.5)
                            table.insert(SkeletonParts, line)
                        end
                    end
                end
                if char:FindFirstChild("LeftUpperArm") then
                    drawBone(char:FindFirstChild("Head"), char:FindFirstChild("UpperTorso"))
                    drawBone(char:FindFirstChild("UpperTorso"), char:FindFirstChild("LowerTorso"))
                    drawBone(char:FindFirstChild("UpperTorso"), char:FindFirstChild("LeftUpperArm"))
                    drawBone(char:FindFirstChild("UpperTorso"), char:FindFirstChild("RightUpperArm"))
                    drawBone(char:FindFirstChild("LowerTorso"), char:FindFirstChild("LeftUpperLeg"))
                    drawBone(char:FindFirstChild("LowerTorso"), char:FindFirstChild("RightUpperLeg"))
                elseif char:FindFirstChild("Left Arm") then
                    drawBone(char:FindFirstChild("Head"), char:FindFirstChild("Torso"))
                    drawBone(char:FindFirstChild("Torso"), char:FindFirstChild("Left Arm"))
                    drawBone(char:FindFirstChild("Torso"), char:FindFirstChild("Right Arm"))
                    drawBone(char:FindFirstChild("Torso"), char:FindFirstChild("Left Leg"))
                    drawBone(char:FindFirstChild("Torso"), char:FindFirstChild("Right Leg"))
                end
            end
        else Billboard.Adornee = nil; BoxHighlight.Adornee = nil end
    end)
end
